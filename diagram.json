{
    "version": 1,
    "editor": "wokwi",
    "parts": [
        {
            "type": "board-esp32-c6-devkitc-1",
            "id": "esp",
            "top": 0,
            "left": 0,
            "rotate": 90,
            "attrs": {
                "flashSize": "8",
                "psramSize": "0",
                "serialInterface": "USB_SERIAL_JTAG" 
            }
        },
        {
            "type": "chip-st7735",
            "id": "tft",
            "top": 150,
            "left": -64,
            "rotate": 90
        },
        {
            "type": "chip-gps-neo6m",
            "id": "gps",
            "top": 40,
            "left": 180,
            "attrs": {}
        }
    ],
    "connections": [
        [ "tft:VCC",  "esp:3V3",  "red",    [] ],
        [ "tft:GND",  "esp:GND.2","black",  [] ],
        [ "tft:MOSI", "esp:7",   "green",  [] ],
        [ "tft:SCK",  "esp:6",   "yellow", [] ],
        [ "tft:DC",  "esp:4",   "purple", [] ],
        [ "tft:RST",  "esp:5",   "blue",   [] ],
        [ "tft:CS",   "esp:18",   "orange", [] ],
        [ "tft:LED",  "esp:24",   "white",  [] ],


        ["gps:VCC", "esp:3V3", "red", ["h0"]],
        ["gps:GND", "esp:GND.1", "black", ["h0"]],
        ["gps:TX", "esp:10", "blue", ["h0"]],
        ["gps:RX", "esp:11", "green", ["v0"]]
    ],
    "serialMonitor": {
        "display": "terminal",
        "convertEol": true
    },
    "dependencies": {
    	"chip-st7735": "github:martysweet/st7735-wokwi-chip@1.0.4",
        "chip-gps-neo6m": "github:erickweil/gps-neo-6m-wokwi-for-vscode@1.0.0"
    }
}
