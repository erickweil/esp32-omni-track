        [ "tft:SCK",  "esp:41",   "yellow", [] ],
        [ "tft:DC",  "esp:40",   "purple", [] ],
        [ "tft:RST",  "esp:39",   "blue",   [] ],
        [ "tft:CS",   "esp:38",   "orange", [] ],
        [ "tft:LED",  "esp:21",   "white",  [] ]
