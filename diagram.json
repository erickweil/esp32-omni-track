{
    "version": 1,
    "editor": "wokwi",
    "parts": [
        {
            "type": "board-esp32-s3-devkitc-1",
            "id": "esp",
            "top": 0,
            "left": 0,
            "rotate": 90,
            "attrs": {
                "flashSize": "8",
                "psramSize": "0",
                "serialInterface": "USB_SERIAL_JTAG" 
            }
        },
        {
            "type": "chip-st7735",
            "id": "tft",
            "top": 150,
            "left": -64,
            "rotate": 90
        }
    ],
    "connections": [
        [ "tft:VCC",  "esp:3V3.1",  "red",    [] ],
        [ "tft:GND",  "esp:GND.3","black",  [] ],
